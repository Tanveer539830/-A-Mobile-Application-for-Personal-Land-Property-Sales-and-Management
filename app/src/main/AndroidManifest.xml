<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Ye line naye mobiles ke liye zaroori hai agar app crash ho rahi ho -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />

    <!-- Queries zaroori hain taake Call/WhatsApp detect ho saken -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FinalYearProject">

        <activity
            android:name=".activites.ChatActivity"
            android:exported="false" />
        <activity
            android:name=".activites.DeleteAccountActivity"
            android:exported="false" />
        <activity
            android:name=".activites.SellerProfileActivity"
            android:exported="false" />
        <activity
            android:name=".activites.PropertyDetailsActivity"
            android:exported="false" />
        <activity
            android:name=".activites.MyPropertyListActivity"
            android:exported="false" />
        <activity
            android:name=".activites.LocationPickerActivity"
            android:exported="false" />
        <activity
            android:name=".activites.PostAddActivity"
            android:exported="false" />
        <activity
            android:name=".activites.ChangePasswordActivity"
            android:exported="false" />
        <activity
            android:name=".activites.ProfileEditActivity"
            android:exported="false" />
        <activity
            android:name=".activites.ForgetPasswordActivity"
            android:exported="false" />
        <activity
            android:name=".activites.LoginPhoneActivity"
            android:exported="false" />
        <activity
            android:name=".activites.RegisterEmailActivity"
            android:exported="false" />
        <activity
            android:name=".activites.MainLoginEmailActivity"
            android:exported="false" />

        <activity
            android:name=".activites.LoginOptionsActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activites.MainActivity"
            android:exported="true" />

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="@string/my_maps_api_key" />
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />
    </application>

</manifest>