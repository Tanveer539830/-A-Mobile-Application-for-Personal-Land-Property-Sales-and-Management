<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activites.LocationPickerActivity">
    <fragment
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:id="@+id/mapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <RelativeLayout
        android:id="@+id/toolbarRl"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@drawable/toolbar_bg02">
        <ImageButton
            android:id="@+id/toolbarBackBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/transparent"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@drawable/arrow_back"
            app:tint="@color/white" />
              <TextView
                  android:id="@+id/toolbarTitleTv"
                  android:layout_width="wrap_content"
                  android:layout_height="match_parent"
                  style="@style/TextAppearance.Material3.TitleMedium"
                  android:text="Pick Location"
                  android:layout_centerHorizontal="true"
                  android:padding="10dp"
                  android:textStyle="bold"
                  android:textColor="@color/white"/>
               <ImageButton
                   android:id="@+id/toolbarGpsBtn"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/gps_white"
                   android:layout_alignParentEnd="true"
                   android:background="@color/transparent"
                   android:padding="10dp"
                   app:tint="@color/white" />
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/searchCv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/toolbarTitleTv"
            android:layout_marginHorizontal="10dp"
            android:layout_margin="10dp"
            android:minWidth="30dp"
            app:cardCornerRadius="20dp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp">
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/autocomplete_fragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:name="com.google.android.libraries.places.widget.AutocompleteSupportFragment"/>

        </com.google.android.material.card.MaterialCardView>
    </RelativeLayout>
    <LinearLayout
        android:id="@+id/doneLl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="10dp"
        android:orientation="vertical">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardUseCompatPadding="true"
            app:contentPadding="10dp">
            <TextView
                android:id="@+id/selectedPlaceTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.BodySmall"
                tools:text="@tools:sample/lorem[8]"/>
        </androidx.cardview.widget.CardView>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/doneBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Done"
            app:icon="@drawable/location_gray"
            android:minHeight="@dimen/m_button_height"/>

    </LinearLayout>
</RelativeLayout>