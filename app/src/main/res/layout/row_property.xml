<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="8dp"
    app:cardUseCompatPadding="true"
    app:contentPadding="10dp"
    app:strokeWidth=".5dp"
    app:strokeColor="@color/colorGray02">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Image Container -->
        <RelativeLayout
            android:id="@+id/profileRl"
            android:layout_width="110dp"
            android:layout_height="130dp"
            android:layout_marginEnd="10dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/propertyIv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:background="@color/colorGray02"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/imageStyle_Corner_Rounded"
                tools:src="@tools:sample/backgrounds/scenic" />
        </RelativeLayout>
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/favouriteBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:alpha=".8"
            android:backgroundTint="@color/colorPrimary"
            app:fabCustomSize="40dp"
            android:src="@drawable/fav_no_black"
            android:tint="@color/white"/>


        <!-- Title -->
        <TextView
            android:id="@+id/titleTv"
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/profileRl"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="Property Title Goes Here" />

        <!-- Description -->
        <TextView
            android:id="@+id/descriptionTv"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/titleTv"
            android:layout_toEndOf="@+id/profileRl"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="This is a short description of the property..." />

        <!-- Tags Container (Purpose, Category, Subcategory) -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/purposeCv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/descriptionTv"
                android:layout_toEndOf="@id/profileRl"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                android:layout_marginVertical="5dp"
                app:strokeColor="@color/colorGray02">

                <TextView
                    android:id="@+id/purposeTv"
                    style="@style/TextAppearance.Material3.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="5dp"
                    tools:text="@tools:sample/lorem[1]"  />
            </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/categoryCv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/descriptionTv"
            android:layout_toEndOf="@id/purposeCv"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            android:layout_marginStart="4dp"
            android:layout_marginVertical="5dp"
            app:strokeColor="@color/colorGray02">

            <TextView
                android:id="@+id/categoryTv"
                style="@style/TextAppearance.Material3.LabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="5dp"
                tools:text="@tools:sample/lorem[1]"  />
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/subcategoryCv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/descriptionTv"
            android:layout_toEndOf="@id/categoryCv"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            android:layout_marginStart="4dp"
            android:layout_marginVertical="5dp"
            app:strokeColor="@color/colorGray02">

            <TextView
                android:id="@+id/subcategoryTv"
                style="@style/TextAppearance.Material3.LabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="5dp"
                tools:text="@tools:sample/lorem[1]"  />
        </com.google.android.material.card.MaterialCardView>

        <!-- Address -->
        <TextView
            android:id="@+id/addressTv"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/profileRl"
            android:ellipsize="end"
            android:layout_below="@id/subcategoryCv"
            android:maxLines="1"
            android:drawableStart="@drawable/location_gray"
            android:drawablePadding="4dp"
            tools:text="@tools:sample/lorem[10]" />

        <!-- Date -->
        <TextView
            android:id="@+id/dateTv"
            style="@style/TextAppearance.Material3.LabelMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/addressTv"
            android:layout_marginTop="8dp"
            android:layout_toEndOf="@+id/profileRl"
            android:gravity="center_vertical"
            app:drawableStartCompat="@drawable/time_gray"
            tools:text="12/10/2023" />

        <!-- Price -->
        <TextView
            android:id="@+id/priceTv"
            style="@style/TextAppearance.Material3.LabelLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/addressTv"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="8dp"
            android:textColor="@color/colorPrimary"
            tools:text="1500"/>

        <!-- Price Symbol -->
        <TextView
            android:id="@+id/priceSymbolTv"
            style="@style/TextAppearance.Material3.LabelLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/addressTv"
            android:layout_toStartOf="@id/priceTv"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="2dp"
            android:text="@string/price_symbol"
            android:textColor="@color/colorPrimary"
            />

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>