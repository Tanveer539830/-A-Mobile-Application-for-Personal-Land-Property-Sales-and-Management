<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activites.MainLoginEmailActivity">

    <!-- Toolbar with App Logo -->
    <RelativeLayout
        android:id="@+id/toolbarRl"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/toolbar_bg02">
        <ImageButton
            android:layout_marginTop="20dp"
            android:id="@+id/toolbarBackBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/arrow_back"
            android:background="@color/transparent"
            android:padding="10dp"
            app:tint="?android:attr/colorLongPressedHighlight" />
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profile_ImageView"
            android:layout_marginTop="20dp"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_centerHorizontal="true"
            android:layout_marginVertical="15dp"
            android:background="@color/white"
            android:src="@drawable/person_black"
            app:shapeAppearanceOverlay="@style/imageStyle_Circle"/>
        <TextView
            android:id="@+id/loginLabelTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LoginTo Your Account"
            android:layout_centerHorizontal="true"
            android:layout_below="@id/profile_ImageView"
            android:textColor="@color/white"
            style="@style/TextAppearance.Material3.TitleMedium"/>
    </RelativeLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbarRl"
        android:padding="10dp">
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/emailTil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Email"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:startIconDrawable="@drawable/mail"
            app:boxCornerRadiusTopStart="8dp">
            <EditText
                android:id="@+id/emailEt"
                android:paddingStart="50dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"/>

        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/passwordTil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="90dp"
            android:hint="Password"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp"
            app:startIconDrawable="@drawable/lock"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/black"> <!-- یہ لائنز پاس ورڈ ٹوگل آن کر دیں گی -->

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/passwordEt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:paddingStart="50dp" />

        </com.google.android.material.textfield.TextInputLayout>
        <TextView
            android:layout_marginTop="5dp"
            android:id="@+id/noAccountTv"
            android:layout_width="wrap_content"
            android:textSize="15dp"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Material3.BodyMedium"
            android:text="@string/no_account_register"
            android:paddingVertical="10dp"
            android:layout_below="@id/passwordTil"/>
              <TextView
                  android:id="@+id/forgetPasswordTv"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/forgetpassword_recover"
                  android:paddingVertical="10dp"
                  android:layout_below="@id/passwordTil"
                  android:textSize="15dp"
                  android:layout_alignParentEnd="true"
                  android:layout_marginTop="5dp"
                  style="@style/TextAppearance.Material3.BodyMedium"/>

<com.google.android.material.button.MaterialButton
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/loginBtn"
    android:text="Login"
    android:layout_alignParentBottom="true"
    android:layout_marginBottom="10dp"
    android:minHeight="@dimen/m_button_height"/>

    </RelativeLayout>

</RelativeLayout>