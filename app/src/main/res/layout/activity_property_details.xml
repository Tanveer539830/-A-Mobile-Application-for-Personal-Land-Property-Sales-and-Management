<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activites.PropertyDetailsActivity">

    <RelativeLayout
        android:id="@+id/toolbarRl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:paddingTop="25dp"
        android:paddingBottom="5dp"
        android:background="@drawable/toolbar_bg01">

        <!-- Back Button: Size 48dp standard hai touch ke liye -->
        <ImageButton
            android:id="@+id/toolbarBackBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="5dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/arrow_back"
            app:tint="@color/white" />

        <!-- Title: Center Vertical se ye har mobile par perfect alignment mein rahega -->
        <TextView
            android:id="@+id/toolbarTitleTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/toolbarBackBtn"
            android:layout_toStartOf="@id/toolBarDeleteBtn"
            android:layout_marginEnd="5dp"
            android:ellipsize="end"
            android:maxLines="1"
            style="@style/TextAppearance.Material3.TitleMedium"
            android:text="Property Detail"
            android:textColor="@color/white" />

        <!-- Right Side Buttons: Inko group kiya gaya hai taake click karna easy ho -->
        <ImageButton
            android:id="@+id/toolBarFavBtn"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="5dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/fav_no_black"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/toolBarEditBtn"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_toStartOf="@id/toolBarFavBtn"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/edit_black"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/toolBarDeleteBtn"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_toStartOf="@id/toolBarEditBtn"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/delete"
            app:tint="@color/white" />

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbarRl"
        android:layout_above="@id/moreOptionsLl">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp">
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/imageSliderVp"
                android:layout_width="match_parent"
                android:layout_height="200dp"/>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/soldCv"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="?attr/colorPrimaryDark"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true"
                app:contentPadding="5dp"
                app:strokeWidth="0dp"
                app:shapeAppearanceOverlay="@style/imageStyle_Circle">
                <TextView
                    style="@style/TextAppearance.Material3.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sold"
                    android:paddingHorizontal="4dp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/priceSymbolTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.LabelMedium"
                android:text="@string/price_symbol"
                android:layout_below="@id/imageSliderVp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/priceTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.LabelMedium"
                android:layout_toEndOf="@id/priceSymbolTv"
                tools:text="12,500"
                android:layout_below="@id/imageSliderVp"
                android:layout_marginEnd="2dp"/>


            <TextView
                android:id="@+id/dateTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.LabelMedium"
                tools:text="@tools:sample/date/ddmmyy"
                android:layout_below="@id/imageSliderVp"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="2dp"/>


            <TextView
                android:id="@+id/purposeLabelTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:text="Purpose"
                android:layout_marginTop="10dp"
                android:layout_below="@id/priceSymbolTv"/>


            <TextView
                android:id="@+id/purposeTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.BodySmall"
                tools:text="@tools:sample/lorem[1]"
                android:layout_below="@id/purposeLabelTv"/>

            <TextView
                android:id="@+id/categoryLabelTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:text="Category"
                android:layout_marginTop="10dp"
                android:layout_below="@id/purposeTv"/>


            <TextView
                android:id="@+id/categoryTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.BodySmall"
                tools:text="@tools:sample/lorem[1]"
                android:layout_below="@id/categoryLabelTv"/>


            <TextView
                android:id="@+id/subcategoryLabelTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:text="Subcategory"
                android:layout_marginTop="10dp"
                android:layout_below="@id/categoryTv"/>


            <TextView
                android:id="@+id/subcategoryTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.BodySmall"
                tools:text="@tools:sample/lorem[1]"
                android:layout_below="@id/subcategoryLabelTv"/>

            <TextView
                android:id="@+id/specificationsLabelTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:text="Specification"
                android:layout_marginTop="10dp"
                android:layout_below="@id/subcategoryTv"/>


            <LinearLayout
                android:id="@+id/moreInfoLl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_below="@id/specificationsLabelTv"
                android:layout_marginTop="4dp">
                <TextView
                    android:id="@+id/floorsTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Material3.LabelSmall"
                    tools:text="Floors:6"
                    android:drawableTop="@drawable/building_gray"
                    android:drawableTint="?attr/colorPrimary"
                    android:gravity="center"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/bedsTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Material3.LabelSmall"
                    tools:text="Beds:6"
                    android:drawableTop="@drawable/bed_gray"
                    android:drawableTint="?attr/colorPrimary"
                    android:gravity="center"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/bathroomsTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Material3.LabelSmall"
                    tools:text="Bathrooms:6"
                    android:drawableTop="@drawable/bathtub_gray"
                    android:drawableTint="?attr/colorPrimary"
                    android:gravity="center"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/areaSizeTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Material3.LabelSmall"
                    tools:text="Area Size:6"
                    android:drawableTop="@drawable/area_size_gray"
                    android:drawableTint="?attr/colorPrimary"
                    android:gravity="center"
                    android:layout_weight="1"/>
            </LinearLayout>

            <TextView
                android:id="@+id/titleLabelTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:text="Title"
                android:layout_marginTop="10dp"
                android:layout_below="@id/moreInfoLl"/>


            <TextView
                android:id="@+id/titleTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.BodySmall"
                tools:text="@tools:sample/lorem[1]"
                android:layout_below="@id/titleLabelTv"/>

            <TextView
                android:id="@+id/descriptionLabelTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:text="Description"
                android:layout_marginTop="10dp"
                android:layout_below="@id/titleTv"/>


            <TextView
                android:id="@+id/descriptionTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.BodySmall"
                tools:text="@tools:sample/lorem[10]"
                android:layout_below="@id/descriptionLabelTv"/>

            <TextView
                android:id="@+id/addressLabelTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:text="Address"
                android:layout_marginTop="10dp"
                android:layout_below="@id/descriptionTv"/>


            <TextView
                android:id="@+id/addressTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.BodySmall"
                tools:text="@tools:sample/lorem[10]"
                android:layout_below="@id/addressLabelTv"/>


            <TextView
                android:id="@+id/sellerProfileLabelTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:text="Seller Info"
                android:layout_marginTop="10dp"
                android:layout_below="@id/addressTv"/>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sellerProfileCv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/sellerProfileLabelTv"
                app:cardCornerRadius="10dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="2dp"
                app:cardMaxElevation="10dp"> <!-- Yahan tabdeeli ki gayi hai -->

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/sellerProfileIv"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:layout_marginEnd="10dp"
                        android:background="@color/colorGray01"
                        tools:src="@tools:sample/avatars"
                        app:shapeAppearanceOverlay="@style/imageStyle_Circle"
                        android:scaleType="centerCrop"/>


                    <TextView
                        android:id="@+id/sellerNameTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Material3.TitleLarge"
                        tools:text="@tools:sample/full_names"
                        android:layout_toEndOf="@id/sellerProfileIv"/>

                    <TextView
                        android:id="@+id/memberSinceLabelTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Material3.LabelSmall"
                        tools:text="@tools:sample/full_names"
                        android:layout_toEndOf="@id/sellerProfileIv"
                        android:layout_below="@id/sellerNameTv"/>


                    <TextView
                        android:id="@+id/memberSinceTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Material3.LabelSmall"
                        tools:text="@tools:sample/date/ddmmyy"
                        android:layout_toEndOf="@id/memberSinceLabelTv"
                        android:layout_below="@id/sellerNameTv"/>


                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/next_gray"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </RelativeLayout>
    </ScrollView>


    <LinearLayout
        android:id="@+id/moreOptionsLl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentBottom="true"
        android:paddingHorizontal="2dp">


        <com.google.android.material.button.MaterialButton
            android:id="@+id/chatBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:minHeight="@dimen/m_button_height"
            android:text="Chat"
            android:textSize="10sp"
            app:cornerRadius="8dp"
            app:icon="@drawable/chat_black"
            app:iconGravity="top"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/callBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:minHeight="@dimen/m_button_height"
            android:text="Call"
            android:textSize="10sp"
            app:cornerRadius="8dp"
            app:icon="@drawable/call_black"
            app:iconGravity="top"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/smsBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:minHeight="@dimen/m_button_height"
            android:text="Sms"
            android:textSize="10sp"
            app:cornerRadius="8dp"
            app:icon="@drawable/chat_black"
            app:iconGravity="top"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mapBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:minHeight="@dimen/m_button_height"
            android:text="Map"
            android:textSize="10sp"
            app:cornerRadius="8dp"
            app:icon="@drawable/location_gray"
            app:iconGravity="top"/>
    </LinearLayout>


</RelativeLayout>